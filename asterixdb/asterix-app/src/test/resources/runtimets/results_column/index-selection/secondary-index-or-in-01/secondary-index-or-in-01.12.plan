distribute result [$$48] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
-- DISTRIBUTE_RESULT  |UNPARTITIONED|
  exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
  -- ONE_TO_ONE_EXCHANGE  |UNPARTITIONED|
    assign [$$48] <- [{"$1": $$50}] project: [$$48] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
    -- ASSIGN  |UNPARTITIONED|
      aggregate [$$50] <- [agg-sql-sum($$52)] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
      -- AGGREGATE  |UNPARTITIONED|
        exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
        -- RANDOM_MERGE_EXCHANGE  |PARTITIONED|
          aggregate [$$52] <- [agg-sql-count(1)] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
          -- AGGREGATE  |PARTITIONED|
            select (and(gt($$o.getField("total"), 5000.0), eq($$o.getField("status"), $$53))) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
            -- STREAM_SELECT  |PARTITIONED|
              project ([$$53, $$o]) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
              -- STREAM_PROJECT  |PARTITIONED|
                exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  unnest-map [$$49, $$o] <- index-search("orders", 0, "Default", "test", "orders", true, false, 1, $$55, 1, $$55, true, true, true) project ({total:any,status:any}) range-filter on: and(gt($$o.getField("total"), 5000.0), or(eq($$o.getField("status"), "pending"), eq($$o.getField("status"), "shipped"))) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                  -- BTREE_SEARCH  |PARTITIONED|
                    exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      order (ASC, $$55) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                      -- STABLE_SORT [$$55(ASC)]  |PARTITIONED|
                        exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          select (eq($$54, $$53)) project: [$$53, $$55] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                          -- STREAM_SELECT  |PARTITIONED|
                            exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              unnest-map [$$54, $$55] <- index-search("idx_order_status_het", 0, "Default", "test", "orders", true, true, 1, $$53, 1, $$53, true, true, true) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                              -- BTREE_SEARCH  |PARTITIONED|
                                exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                -- BROADCAST_EXCHANGE  |PARTITIONED|
                                  unnest $$53 <- scan-collection(array: [ "pending", "shipped" ]) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                  -- UNNEST  |PARTITIONED|
                                    empty-tuple-source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                    -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
