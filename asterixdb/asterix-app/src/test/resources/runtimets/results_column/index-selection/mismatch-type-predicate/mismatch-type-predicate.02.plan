distribute result [$$19] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    select (or(eq($$20, "1"), eq($$20, 0))) project: [$$19] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
    -- STREAM_SELECT  |PARTITIONED|
      assign [$$19, $$20] <- [$$tenk.getField(0), $$tenk.getField("thousand")] project: [$$19, $$20] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
      -- ASSIGN  |PARTITIONED|
        project ([$$tenk]) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
        -- STREAM_PROJECT  |PARTITIONED|
          exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
            data-scan []<-[$$21, $$tenk] <- test.tenk project ({unique1:any,thousand:any}) filter on: or(eq($$tenk.getField("thousand"), "1"), eq($$tenk.getField("thousand"), 0)) range-filter on: or(eq($$tenk.getField("thousand"), "1"), eq($$tenk.getField("thousand"), 0)) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
            -- DATASOURCE_SCAN  |PARTITIONED|
              exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                empty-tuple-source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
