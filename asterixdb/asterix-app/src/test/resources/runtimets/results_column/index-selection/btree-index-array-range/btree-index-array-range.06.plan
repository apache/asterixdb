distribute result [$$37] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$37] <- [{"A": $$A, "item": $$item}] project: [$$37] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
    -- ASSIGN  |PARTITIONED|
      project ([$$A, $$item]) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
      -- STREAM_PROJECT  |PARTITIONED|
        exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
        -- SORT_MERGE_EXCHANGE [$$39(ASC) ]  |PARTITIONED|
          order (ASC, $$39) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
          -- STABLE_SORT [$$39(ASC)]  |PARTITIONED|
            exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              select (or(eq($$30, 120), eq($$30, 80))) project: [$$A, $$item, $$39] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
              -- STREAM_SELECT  |PARTITIONED|
                assign [$$30] <- [$$item.getField("qty")] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                -- ASSIGN  |PARTITIONED|
                  unnest $$item <- scan-collection($$40) project: [$$39, $$A, $$item] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                  -- UNNEST  |PARTITIONED|
                    select (or(eq($$33, 1000), eq($$33, 1001))) project: [$$39, $$A, $$40] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                    -- STREAM_SELECT  |PARTITIONED|
                      assign [$$33, $$40] <- [$$A.getField("a_2"), $$A.getField("items")] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                      -- ASSIGN  |PARTITIONED|
                        exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          data-scan []<-[$$39, $$A] <- test.A filter on: and(or(eq($$A.getField("a_2"), 1000), eq($$A.getField("a_2"), 1001)), or(eq(scan-collection($$A.getField("items")).getField("qty"), 120), eq(scan-collection($$A.getField("items")).getField("qty"), 80))) range-filter on: and(or(eq($$A.getField("a_2"), 1000), eq($$A.getField("a_2"), 1001)), or(eq(scan-collection($$A.getField("items")).getField("qty"), 120), eq(scan-collection($$A.getField("items")).getField("qty"), 80))) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                          -- DATASOURCE_SCAN  |PARTITIONED|
                            exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              empty-tuple-source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
