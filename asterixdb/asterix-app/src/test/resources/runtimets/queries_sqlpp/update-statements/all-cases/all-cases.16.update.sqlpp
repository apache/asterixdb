Use test;

UPDATE orders as o
(INSERT INTO o.items ([
    {
      "itemno": 501,
      "qty": 24,
      "price": 46
    },
    {
      "itemno": 550,
      "qty": 60,
      "price": 20
    }
]))
WHERE o.orderno = 1006;
