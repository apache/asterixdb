Use test;

UPDATE orders as o
(DELETE FROM o.items AT ord WHERE ord IN [0,1])
(INSERT INTO o.items AT 1 ([
    {
      "itemno": 345,
      "qty": 20,
      "price": 10.5
    }]))
WHERE o.orderno = 1006;

