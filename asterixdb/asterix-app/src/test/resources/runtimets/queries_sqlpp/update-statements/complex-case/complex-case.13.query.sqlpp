use test;

UPDATE UserTypes2 AS u
set u.c_purchase_history={"a1":33}
set u.c_purchase_history2={"a2":33}
WHERE u.userId= 3;

UPDATE UserTypes2 AS u
set u.c_purchase_history.c_recent_orders=["a","5"]
set u.a="p"
set u.isActive=Missing
WHERE u.userId= 4;


UPDATE UserTypes2 AS u
set u={"userId":5}
WHERE u.userId= 5;


select * from UserTypes2
order by userId;