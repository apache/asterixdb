DROP DATAVERSE test IF EXISTS;
CREATE DATAVERSE test;
USE test;

CREATE TYPE CustomerType AS {
  custid: string
};

CREATE DATASET customers(CustomerType) PRIMARY KEY custid;

INSERT INTO customers [
  {
    "custid": "C47",
    "name": "S. Logan",
