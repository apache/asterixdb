    "name": "S. Paul",
    "address": {
      "city": "San Jose, United States",
      "street" : "North First Street",
      "zipcode" : 95134
    },
    "rating": 775
  }
];


CREATE TYPE OrderType AS {
  orderno: int
};

CREATE DATASET orders(OrderType) PRIMARY KEY orderno;

