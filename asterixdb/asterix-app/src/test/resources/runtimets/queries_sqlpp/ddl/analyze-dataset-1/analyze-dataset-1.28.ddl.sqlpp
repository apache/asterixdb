/*
 * Description: the "sample-method" WITH option ("full-scan" | "random"), matching the vocabulary stored
 *              in the index metadata. "full-scan" is deterministic (never downgraded to another method),
 *              so its stored method can be asserted directly in the next step. ds1 was dropped earlier in
 *              this suite, so it is recreated and populated here.
 */

use test;

create dataset ds1(t1) primary key id;

insert into ds1 ([{"id": 1}, {"id": 2}, {"id": 3}]);

analyze dataset ds1 with { "sample-method": "full-scan", "sample-seed": 1000 };
