/*
 * Description: Intersection of a standard typed index (idx_order_status) and
 *              an array index (idx_order_tags).
 *              status = "pending" AND tags contains "urgent".
 */

use test;

SET `rewrite_or_as_join` "false";

EXPLAIN
SELECT count(*)
FROM orders o, o.tags t
WHERE o.status = "pending"
  AND t = "urgent";
