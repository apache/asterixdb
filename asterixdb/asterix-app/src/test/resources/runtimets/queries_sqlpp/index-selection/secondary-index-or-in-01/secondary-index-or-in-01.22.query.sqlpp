/*
 * Description: IN clause on array index over objects inside an array
 *              (UNNEST o_orderline SELECT ol_item).
 *              Expect idx_orderline_item to be used.
 */

use test;

SET `rewrite_or_as_join` "false";

EXPLAIN
SELECT count(*)
FROM orders o, o.o_orderline ol
WHERE ol.ol_item IN ["item_1", "item_10", "item_25"];
