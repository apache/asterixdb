/*
 * Description: Intersection of standard index (OR clause) with nested array index (IN clause).
 *              (region = "east" OR region = "west") AND ol_item IN [...].
 *              Expect intersection of idx_order_region and idx_orderline_item.
 */

use test;

SET `rewrite_or_as_join` "false";

EXPLAIN
SELECT count(*)
FROM orders o, o.o_orderline ol
WHERE (o.region = "east" OR o.region = "west")
  AND ol.ol_item IN ["item_1", "item_10"];
