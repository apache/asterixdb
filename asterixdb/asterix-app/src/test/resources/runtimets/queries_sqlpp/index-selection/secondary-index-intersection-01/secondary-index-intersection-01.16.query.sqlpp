/*
 * Description: Intersection of three indexes: two standard (idx_order_status,
 *              idx_order_priority) and one array (idx_order_tags).
 *              status = "shipped" AND priority = 1 AND tag = "retail".
 */

use test;

SET `rewrite_or_as_join` "false";

EXPLAIN
SELECT count(*)
FROM orders o, o.tags t
WHERE o.status = "shipped"
  AND o.priority = 1
  AND t = "retail";
