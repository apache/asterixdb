/*
 * Create separate indexes so that intersection can be tested.
 * Standard (typed) indexes, heterogeneous indexes, and array indexes.
 */

use test;

-- Standard typed indexes (separate, for intersection)
CREATE INDEX idx_order_status ON orders(status : string);
CREATE INDEX idx_order_region ON orders(region : string);
CREATE INDEX idx_order_priority ON orders(priority : integer);
CREATE INDEX idx_order_total ON orders(total : double);

-- Heterogeneous indexes (separate, for intersection)
CREATE INDEX idx_cust_city ON customers(city);
CREATE INDEX idx_cust_tier ON customers(tier);
CREATE INDEX idx_cust_age ON customers(age);

-- Array indexes (typed)
CREATE INDEX idx_order_tags ON orders(UNNEST tags : string) EXCLUDE UNKNOWN KEY;
CREATE INDEX idx_cust_interests ON customers(UNNEST interests : string) EXCLUDE UNKNOWN KEY;

-- Array index on nested field within array of objects
CREATE INDEX idx_orderline_item ON orders(UNNEST o_orderline SELECT ol_item : string) EXCLUDE UNKNOWN KEY;
CREATE INDEX idx_orderline_delivery ON orders(UNNEST o_orderline SELECT ol_delivery_d : string) EXCLUDE UNKNOWN KEY;
