USE Metadata;

CREATE COORDINATE REFERENCE SYSTEM 4326
  NAME 'WGS 84'
  AS 'GEOGCS["WGS 84",DATUM["WGS_1984",SPHEROID["WGS 84",6378137,298.257223563]],PRIMEM["Greenwich",0],UNIT["degree",0.0174532925199433]]';
