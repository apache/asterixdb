use GeoJSONCRS;

SELECT g.id,
       round(st_x(st_transform(g.myGeometry, 4326, 3857))) as x_3857,
       round(st_y(st_transform(g.myGeometry, 4326, 3857))) as y_3857
FROM CRSGeometries g
ORDER BY g.id;
