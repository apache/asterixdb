{
"numpoints_line":            st_numpoints(st_geomfromtext("LINESTRING(0 0, 1 1, 2 2, 3 3)")),
"numpoints_nonline":         st_numpoints(st_geomfromtext("POINT(0 0)")),
"multi_point":               st_aswkt(st_multi(st_geomfromtext("POINT(1 2)"))),
"multi_linestring":          st_aswkt(st_multi(st_geomfromtext("LINESTRING(0 0, 1 1)"))),
"multi_polygon":             st_aswkt(st_multi(st_geomfromtext("POLYGON((0 0, 1 0, 1 1, 0 1, 0 0))"))),
"multi_passthrough":         st_aswkt(st_multi(st_geomfromtext("MULTIPOINT(0 0, 1 1)"))),
"collection_extract_points": st_aswkt(st_collectionextract(st_geomfromtext("GEOMETRYCOLLECTION(POINT(1 1), LINESTRING(0 0, 2 2), POINT(3 3))"), 1)),
"collection_extract_lines":  st_aswkt(st_collectionextract(st_geomfromtext("GEOMETRYCOLLECTION(POINT(1 1), LINESTRING(0 0, 2 2), POINT(3 3))"), 2)),
"unary_union_overlap":       st_aswkt(st_unaryunion(st_geomfromtext("MULTIPOLYGON(((0 0, 2 0, 2 2, 0 2, 0 0)), ((1 1, 3 1, 3 3, 1 3, 1 1)))"))),
"normalize_polygon":         st_aswkt(st_normalize(st_geomfromtext("POLYGON((0 0, 1 0, 1 1, 0 1, 0 0))"))),
"isvalidreason_valid":       st_isvalidreason(st_geomfromtext("POLYGON((0 0, 1 0, 1 1, 0 1, 0 0))")),
"isvalidreason_bowtie":      st_isvalidreason(st_geomfromtext("POLYGON((0 0, 1 1, 1 0, 0 1, 0 0))")),
"relatematch_true":          st_relatematch("FF0FFF212", "FF*FF****"),
"relatematch_false":         st_relatematch("FF0FFF212", "T********")
};
