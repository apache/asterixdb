{
"as_geojson_xy":          st_asgeojson(st_makepoint(1.0, 2.0)),
"as_geojson_xyz":         st_asgeojson(st_makepoint(1.0, 2.0, 3.0)),
"as_geojson_xyzm":        st_asgeojson(st_makepoint(1.0, 2.0, 3.0, 4.0)),
"from_geojson_xy_x":      st_x(st_geom_from_geojson({"type":"Point","coordinates":[1,2]})),
"from_geojson_xyz_z":     st_z(st_geom_from_geojson({"type":"Point","coordinates":[1,2,3]})),
"from_geojson_xyzm_z":    st_z(st_geom_from_geojson({"type":"Point","coordinates":[1,2,3,4]})),
"from_geojson_xyzm_m":    st_m(st_geom_from_geojson({"type":"Point","coordinates":[1,2,3,4]})),
"round_trip_xyzm":        st_asgeojson(st_geom_from_geojson({"type":"Point","coordinates":[1,2,3,4]}))
};
