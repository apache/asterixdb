{
"makepoint_2d":       st_aswkt(st_makepoint(1.0, 2.0)),
"makeenvelope":       st_aswkt(st_makeenvelope(0.0, 0.0, 10.0, 10.0, 4326)),
"linefrommultipoint": st_aswkt(st_linefrommultipoint(st_geomfromtext("MULTIPOINT(1 2, 4 5, 7 8)"))),
"exteriorring":       st_aswkt(st_exteriorring(st_geomfromtext("POLYGON((0 0, 10 0, 10 10, 0 10, 0 0))"))),
"symdifference":      st_aswkt(st_symdifference(st_geomfromtext("POLYGON((0 0, 10 0, 10 10, 0 10, 0 0))"), st_geomfromtext("POLYGON((5 5, 15 5, 15 15, 5 15, 5 5))"))),
"flipcoordinates":    st_aswkt(st_flipcoordinates(st_geomfromtext("POINT(1 2)")))
};
