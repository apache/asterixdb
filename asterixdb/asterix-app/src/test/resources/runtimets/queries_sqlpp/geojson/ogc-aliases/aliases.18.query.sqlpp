{
"linemerge_single":         st_aswkt(st_linemerge(st_geomfromtext("LINESTRING(0 0, 1 1)"))),
"linemerge_disconnected":   st_aswkt(st_linemerge(st_geomfromtext("MULTILINESTRING((0 0, 1 1), (5 5, 6 6))"))),
"pointonsurface_of_point":  st_aswkt(st_pointonsurface(st_geomfromtext("POINT(7 8)"))),
"pointonsurface_of_line":   st_aswkt(st_pointonsurface(st_geomfromtext("LINESTRING(0 0, 10 0)"))),
"simplify_zero_tolerance":  st_aswkt(st_simplify(st_geomfromtext("LINESTRING(0 0, 1 1, 2 2)"), 0.0)),
"simplify_pt_zero":         st_aswkt(st_simplifypreservetopology(st_geomfromtext("POLYGON((0 0, 10 0, 10 10, 0 10, 0 0))"), 0.0)),
"concavehull_full_ratio":   st_aswkt(st_concavehull(st_geomfromtext("MULTIPOINT(0 0, 10 0, 10 10, 0 10)"), 1.0))
};
