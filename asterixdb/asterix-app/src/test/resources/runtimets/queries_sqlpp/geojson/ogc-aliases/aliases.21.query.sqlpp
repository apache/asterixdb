{
"mixed_case_isempty":         ST_IsEmpty(ST_GeomFromText("LINESTRING EMPTY")),
"mixed_case_makepoint":       ST_AsText(ST_MakePoint(1.0, 2.0)),
"mixed_case_pointn":          ST_AsText(ST_PointN(ST_GeomFromText("LINESTRING(0 0, 1 1, 2 2)"), 1)),
"mixed_case_geomtype":        ST_GeometryType(ST_GeomFromText("POINT(1 2)")),
"mixed_case_numgeometries":   ST_NumGeometries(ST_GeomFromText("GEOMETRYCOLLECTION(POINT(0 0), POINT(1 1), POINT(2 2))")),
"mixed_case_xmax":            ST_XMax(ST_GeomFromText("POLYGON((0 0, 5 0, 5 5, 0 5, 0 0))")),
"mixed_case_geomfromgeojson": ST_X(ST_GeomFromGeoJSON({"type":"Point","coordinates":[7.5, 8.5]}))
};
