drop dataverse test1 if exists;
create dataverse test1;

use test1;

create dataset t1(c_id int32 not unknown) open type primary key c_id;

create view v1(c_id int32, c_val int64) default null as select c_id, c_val from t1;

-- replace the typed view with an untyped one;
create or replace view v1 as select c_id, c_val from t1;
