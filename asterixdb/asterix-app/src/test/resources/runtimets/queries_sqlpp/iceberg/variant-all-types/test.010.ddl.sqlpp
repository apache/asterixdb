DROP COLLECTION allTypesVariant IF EXISTS;
DROP TYPE allTypesVariant IF EXISTS;

CREATE TYPE allTypesVariant AS open {};
CREATE EXTERNAL COLLECTION allTypesVariant(allTypesVariant)
USING S3
(
    ("table-format"="iceberg"),
    ("namespace"="my_namespace"),
    ("tableName"="allTypesVariant"),
    ("region"="custom-region"),
    ("serviceEndpoint"="%DOCKER_S3_CONTAINER%"),
    ("pathStyleAddressing"="true"),
    ("catalogName"="myNessieCatalog"),
    ("format"="parquet"),
    ("decimal-to-double"="true")
);

DROP COLLECTION allTypesVariantZoneId IF EXISTS;
DROP TYPE allTypesVariantZoneId IF EXISTS;

CREATE TYPE allTypesVariantZoneId AS open {};
CREATE EXTERNAL COLLECTION allTypesVariantZoneId(allTypesVariantZoneId)
USING S3
(
    ("table-format"="iceberg"),
    ("namespace"="my_namespace"),
    ("tableName"="allTypesVariant"),
    ("region"="custom-region"),
    ("serviceEndpoint"="%DOCKER_S3_CONTAINER%"),
    ("pathStyleAddressing"="true"),
    ("catalogName"="myNessieCatalog"),
    ("format"="parquet"),
    ("decimal-to-double"="true"),
    ("timezone"="GMT+01:00")
);

-- Regression test: an empty variantDepth value must not crash (it should fall back to the default),
-- unlike a bare Integer.parseInt(getOrDefault(...)) which would throw on "".
DROP COLLECTION allTypesVariantEmptyDepth IF EXISTS;
DROP TYPE allTypesVariantEmptyDepth IF EXISTS;

CREATE TYPE allTypesVariantEmptyDepth AS open {};
CREATE EXTERNAL COLLECTION allTypesVariantEmptyDepth(allTypesVariantEmptyDepth)
USING S3
(
    ("table-format"="iceberg"),
    ("namespace"="my_namespace"),
    ("tableName"="allTypesVariant"),
    ("region"="custom-region"),
    ("serviceEndpoint"="%DOCKER_S3_CONTAINER%"),
    ("pathStyleAddressing"="true"),
    ("catalogName"="myNessieCatalog"),
    ("format"="parquet"),
    ("decimal-to-double"="true"),
    ("variantDepth"="")
);

-- Coverage for isTimestampAsLong() on the Variant path: with timestamp-to-long=true a Variant
-- TIMESTAMPTZ/NTZ (and their _NANOS forms) must serialize as raw epoch micros/nanos (bigint), not
-- datetime. timezone is kept so we also prove zone projection still runs before long serialization
-- for the TZ (zoned) forms.
DROP COLLECTION allTypesVariantTsAsLong IF EXISTS;
DROP TYPE allTypesVariantTsAsLong IF EXISTS;

CREATE TYPE allTypesVariantTsAsLong AS open {};
CREATE EXTERNAL COLLECTION allTypesVariantTsAsLong(allTypesVariantTsAsLong)
USING S3
(
    ("table-format"="iceberg"),
    ("namespace"="my_namespace"),
    ("tableName"="allTypesVariant"),
    ("region"="custom-region"),
    ("serviceEndpoint"="%DOCKER_S3_CONTAINER%"),
    ("pathStyleAddressing"="true"),
    ("catalogName"="myNessieCatalog"),
    ("format"="parquet"),
    ("decimal-to-double"="true"),
    ("timezone"="GMT+01:00"),
    ("timestamp-to-long"="true")
);
