DROP COLLECTION users IF EXISTS;
DROP TYPE users IF EXISTS;

CREATE TYPE users AS open {};
CREATE EXTERNAL COLLECTION usersNoSnapshot(users)
USING S3
(
    ("table-format"="iceberg"),
    ("namespace"="my_namespace"),
    ("tableName"="users"),
    ("region"="custom-region"),
    ("serviceEndpoint"="%DOCKER_S3_CONTAINER%"),
    ("pathStyleAddressing"="true"),
    ("catalogName"="myNessieCatalog"),
    ("format"="parquet"),
    ("decimal-to-double"="true"),
    ("date-to-int"="true"),
    ("time-to-int"="true"),
    ("timestamp-to-long"="true")
);

CREATE EXTERNAL COLLECTION usersYesSnapshot(users)
USING S3
(
    ("table-format"="iceberg"),
    ("namespace"="my_namespace"),
    ("tableName"="users"),
    ("region"="custom-region"),
    ("serviceEndpoint"="%DOCKER_S3_CONTAINER%"),
    ("pathStyleAddressing"="true"),
    ("catalogName"="myNessieCatalog"),
    ("format"="parquet"),
    ("decimal-to-double"="true"),
    ("date-to-int"="true"),
    ("time-to-int"="true"),
    ("timestamp-to-long"="true"),
    ("snapshotId"="%SNAPSHOT_1_SNAPSHOT_ID%")
);