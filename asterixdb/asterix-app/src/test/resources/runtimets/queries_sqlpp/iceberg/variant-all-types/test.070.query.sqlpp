-- Same variant timestamp fields as test.050, but read through a collection with
-- timestamp-to-long=true, so they must come back as raw epoch micros/nanos (bigint)
-- rather than datetime. The GMT+01:00 offset is still applied to the zoned (TZ) forms
-- before serialization.
SELECT variant_field.timestamptzValue AS timestamptzValue,
       variant_field.timestampntzValue AS timestampntzValue,
       variant_field.timestamptzNanosValue AS timestamptzNanosValue,
       variant_field.timestampntzNanosValue AS timestampntzNanosValue
FROM allTypesVariantTsAsLong
WHERE id = 1;
