USE test;

/*
 * Test row-group filters with AND combining a nested string field and a double
 * comparison on a field inside an UNNEST'd array.  The array predicate path
 * (o.amount) may not resolve to a supported Parquet column; the builder must
 * degrade gracefully (return null for that branch) so the AND still applies
 * the valid nested-field filter without throwing an error.
 * Logs should not contain "Error creating Parquet row-group filter expression"
 */

SELECT c.id, c.name, o.order_id, o.amount
FROM DatasetCopy c
UNNEST c.orders o
WHERE c.address.city = "Bangalore" AND o.amount > 100.0
ORDER BY c.id, o.order_id;
