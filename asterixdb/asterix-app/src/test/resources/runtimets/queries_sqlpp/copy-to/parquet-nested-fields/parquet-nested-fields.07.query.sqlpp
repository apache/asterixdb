USE test;

/*
 * Test that OR predicates on nested fields produce correct row-group filters.
 * The OR branch must return null conservatively if either side cannot be evaluated,
 * but when both sides are valid the filter should be applied correctly.
 * Logs should not contain "Error creating Parquet row-group filter expression"
 */

SELECT c.id, c.name
FROM DatasetCopy c
WHERE c.address.city = "Bangalore" OR c.address.city = "New York"
ORDER BY c.id;
