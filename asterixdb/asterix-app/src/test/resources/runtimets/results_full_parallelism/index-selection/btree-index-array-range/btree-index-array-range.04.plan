distribute result [$$30] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$30] <- [{"A": $$A, "cat": $$cat}] project: [$$30] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
    -- ASSIGN  |PARTITIONED|
      project ([$$A, $$cat]) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
      -- STREAM_PROJECT  |PARTITIONED|
        exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
        -- SORT_MERGE_EXCHANGE [$$32(ASC) ]  |PARTITIONED|
          order (ASC, $$32) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
          -- STABLE_SORT [$$32(ASC)]  |PARTITIONED|
            exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              select (or(eq($$cat, "Food"), eq($$cat, "Restaurant"))) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
              -- STREAM_SELECT  |PARTITIONED|
                unnest $$cat <- scan-collection($$33) project: [$$32, $$A, $$cat] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                -- UNNEST  |PARTITIONED|
                  assign [$$33] <- [$$A.getField("categories")] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                  -- ASSIGN  |PARTITIONED|
                    project ([$$32, $$A]) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                    -- STREAM_PROJECT  |PARTITIONED|
                      exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                        unnest-map [$$32, $$A] <- index-search("A", 0, "Default", "test", "A", true, false, 1, $$37, 1, $$37, true, true, true) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                        -- BTREE_SEARCH  |PARTITIONED|
                          exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                            distinct ([$$37]) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                            -- PRE_SORTED_DISTINCT_BY  |PARTITIONED|
                              exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                order (ASC, $$37) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                -- STABLE_SORT [$$37(ASC)]  |PARTITIONED|
                                  exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                    project ([$$37]) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                    -- STREAM_PROJECT  |PARTITIONED|
                                      exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                        unnest-map [$$36, $$37] <- index-search("idx_categories", 0, "Default", "test", "A", true, true, 1, $$35, 1, $$35, true, true, true) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                        -- BTREE_SEARCH  |PARTITIONED|
                                          exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                          -- BROADCAST_EXCHANGE  |PARTITIONED|
                                            unnest $$35 <- scan-collection(array: [ "Food", "Restaurant" ]) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                            -- UNNEST  |PARTITIONED|
                                              empty-tuple-source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                              -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
