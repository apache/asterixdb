distribute result [$$48] [cardinality: 110.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
-- DISTRIBUTE_RESULT  |UNPARTITIONED|
  exchange [cardinality: 110.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
  -- ONE_TO_ONE_EXCHANGE  |UNPARTITIONED|
    assign [$$48] <- [{"$1": $$50}] project: [$$48] [cardinality: 110.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
    -- ASSIGN  |UNPARTITIONED|
      aggregate [$$50] <- [agg-sql-sum($$52)] [cardinality: 110.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
      -- AGGREGATE  |UNPARTITIONED|
        exchange [cardinality: 110.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
        -- RANDOM_MERGE_EXCHANGE  |PARTITIONED|
          aggregate [$$52] <- [agg-sql-count(1)] [cardinality: 110.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
          -- AGGREGATE  |PARTITIONED|
            select (and(gt($$c.getField("age"), 40), or(eq($$37, "New York"), eq($$37, "Chicago")))) [cardinality: 110.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
            -- STREAM_SELECT  |PARTITIONED|
              assign [$$37] <- [$$c.getField("city")] [cardinality: 500.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
              -- ASSIGN  |PARTITIONED|
                project ([$$c]) [cardinality: 500.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
                -- STREAM_PROJECT  |PARTITIONED|
                  exchange [cardinality: 500.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                    data-scan []<-[$$49, $$c] <- test.customers [cardinality: 500.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
                    -- DATASOURCE_SCAN  |PARTITIONED|
                      exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                        empty-tuple-source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                        -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
