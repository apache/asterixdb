                select (and(eq($$c.getField("tier"), "gold"), or(eq($$51, "New York"), eq($$51, "Chicago"), eq($$51, "Houston")))) project: [$$67] [cardinality: 500.0, doc-size: 0.0, op-cost: 0.0, total-cost: 500.0]
