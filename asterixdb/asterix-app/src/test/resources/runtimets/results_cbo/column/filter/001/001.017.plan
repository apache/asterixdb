distribute result [$$d] [cardinality: 4.0, doc-size: 106.0, op-cost: 0.0, total-cost: 14.0]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange [cardinality: 4.0, doc-size: 106.0, op-cost: 0.0, total-cost: 14.0]
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    project ([$$d]) [cardinality: 4.0, doc-size: 106.0, op-cost: 0.0, total-cost: 14.0]
    -- STREAM_PROJECT  |PARTITIONED|
      exchange [cardinality: 4.0, doc-size: 106.0, op-cost: 0.0, total-cost: 14.0]
      -- SORT_MERGE_EXCHANGE [$$32(ASC) ]  |PARTITIONED|
        order (ASC, $$32) [cardinality: 4.0, doc-size: 106.0, op-cost: 8.0, total-cost: 14.0]
        -- STABLE_SORT [$$32(ASC)]  |PARTITIONED|
          exchange [cardinality: 4.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
            select ($$30) project: [$$d, $$32] [cardinality: 4.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
            -- STREAM_SELECT  |PARTITIONED|
              project ([$$32, $$d, $$30]) [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
              -- STREAM_PROJECT  |PARTITIONED|
                subplan {
                          aggregate [$$30] <- [non-empty-stream()] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                          -- AGGREGATE  |LOCAL|
                            select (lt($$a, 100.1)) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                            -- STREAM_SELECT  |LOCAL|
                              unnest $$a <- scan-collection($$33) project: [$$a] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                              -- UNNEST  |LOCAL|
                                project ([$$33]) [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                -- STREAM_PROJECT  |LOCAL|
                                  nested tuple source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                  -- NESTED_TUPLE_SOURCE  |LOCAL|
                       } [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
                -- SUBPLAN  |PARTITIONED|
                  assign [$$33] <- [$$d.getField("array")] [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
                  -- ASSIGN  |PARTITIONED|
                    exchange [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      data-scan []<-[$$32, $$d] <- test.ColumnDataset filter on: lt(scan-collection($$d.getField("array")), 100.1) range-filter on: lt(scan-collection($$d.getField("array")), 100.1) [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
                      -- DATASOURCE_SCAN  |PARTITIONED|
                        exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          empty-tuple-source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                          -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
