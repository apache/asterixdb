distribute result [$$20] [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 4.0]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 4.0]
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$20] <- [{"display_url": $$24}] project: [$$20] [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 4.0]
    -- ASSIGN  |PARTITIONED|
      project ([$$24]) [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 4.0]
      -- STREAM_PROJECT  |PARTITIONED|
        exchange [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 4.0]
        -- SORT_MERGE_EXCHANGE [$$22(ASC) ]  |PARTITIONED|
          order (ASC, $$22) [cardinality: 2.0, doc-size: 0.0, op-cost: 2.0, total-cost: 4.0]
          -- STABLE_SORT [$$22(ASC)]  |PARTITIONED|
            exchange [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              assign [$$24] <- [get-item($$p.getField("entities").getField("urls"), 0).getField("display_url")] project: [$$24, $$22] [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
              -- ASSIGN  |PARTITIONED|
                exchange [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  data-scan []<-[$$22, $$p] <- test.ColumnDataset project ({entities:{urls:[{display_url:any}]}}) [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
                  -- DATASOURCE_SCAN  |PARTITIONED|
                    exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      empty-tuple-source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                      -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
