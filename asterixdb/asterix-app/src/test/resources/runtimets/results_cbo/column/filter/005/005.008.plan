distribute result [$$55] [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
-- DISTRIBUTE_RESULT  |UNPARTITIONED|
  exchange [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
  -- ONE_TO_ONE_EXCHANGE  |UNPARTITIONED|
    assign [$$55] <- [{"$1": $$57}] project: [$$55] [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
    -- ASSIGN  |UNPARTITIONED|
      aggregate [$$57] <- [agg-sql-sum($$59)] [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
      -- AGGREGATE  |UNPARTITIONED|
        exchange [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
        -- RANDOM_MERGE_EXCHANGE  |PARTITIONED|
          aggregate [$$59] <- [agg-sql-count(1)] [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
          -- AGGREGATE  |PARTITIONED|
            select (gt(numeric-add($$D, 1), 2018)) [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
            -- STREAM_SELECT  |PARTITIONED|
              unnest $$D <- scan-collection($$58) project: [$$D] [cardinality: 30.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
              -- UNNEST  |PARTITIONED|
                assign [$$58] <- [$$C.getField("dates")] project: [$$58] [cardinality: 30.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
                -- ASSIGN  |PARTITIONED|
                  project ([$$C]) [cardinality: 30.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
                  -- STREAM_PROJECT  |PARTITIONED|
                    exchange [cardinality: 30.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      data-scan []<-[$$56, $$C] <- TestYelp.YelpCheckin project ({dates:[any]}) filter on: gt(numeric-add(scan-collection($$C.getField("dates")), 1), 2018) [cardinality: 30.0, doc-size: 0.0, op-cost: 0.0, total-cost: 30.0]
                      -- DATASOURCE_SCAN  |PARTITIONED|
                        exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          empty-tuple-source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                          -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
