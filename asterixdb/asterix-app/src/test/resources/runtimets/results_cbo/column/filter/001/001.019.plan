distribute result [$$item] [cardinality: 3.0, doc-size: 106.0, op-cost: 0.0, total-cost: 10.75]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange [cardinality: 3.0, doc-size: 106.0, op-cost: 0.0, total-cost: 10.75]
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    project ([$$item]) [cardinality: 3.0, doc-size: 106.0, op-cost: 0.0, total-cost: 10.75]
    -- STREAM_PROJECT  |PARTITIONED|
      exchange [cardinality: 3.0, doc-size: 106.0, op-cost: 0.0, total-cost: 10.75]
      -- SORT_MERGE_EXCHANGE [$$33(ASC), $$item(ASC) ]  |PARTITIONED|
        order (ASC, $$33) (ASC, $$item) [cardinality: 3.0, doc-size: 106.0, op-cost: 4.75, total-cost: 10.75]
        -- STABLE_SORT [$$33(ASC), $$item(ASC)]  |PARTITIONED|
          exchange [cardinality: 3.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
            select (and(gt($$item, 60), lt($$item, 100))) [cardinality: 3.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
            -- STREAM_SELECT  |PARTITIONED|
              unnest $$item <- scan-collection($$34) project: [$$33, $$item] [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
              -- UNNEST  |PARTITIONED|
                assign [$$34] <- [$$d.getField("array")] project: [$$33, $$34] [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
                -- ASSIGN  |PARTITIONED|
                  exchange [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                    data-scan []<-[$$33, $$d] <- test.ColumnDataset project ({array:[any]}) filter on: and(gt(scan-collection($$d.getField("array")), 60), lt(scan-collection($$d.getField("array")), 100)) range-filter on: and(gt(scan-collection($$d.getField("array")), 60), lt(scan-collection($$d.getField("array")), 100)) [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
                    -- DATASOURCE_SCAN  |PARTITIONED|
                      exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                        empty-tuple-source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                        -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
