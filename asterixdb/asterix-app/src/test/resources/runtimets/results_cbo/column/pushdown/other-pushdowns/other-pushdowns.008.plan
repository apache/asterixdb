distribute result [$$78] [cardinality: 1.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange [cardinality: 1.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$78] <- [{"text": $$text, "$1": $$82}] project: [$$78] [cardinality: 1.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
    -- ASSIGN  |PARTITIONED|
      exchange [cardinality: 1.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
      -- SORT_MERGE_EXCHANGE [$$text(ASC) ]  |PARTITIONED|
        group by ([$$text := $$90]) decor ([]) {
                  aggregate [$$82] <- [agg-global-sql-sum($$89)] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                  -- AGGREGATE  |LOCAL|
                    nested tuple source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                    -- NESTED_TUPLE_SOURCE  |LOCAL|
               } [cardinality: 1.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
        -- SORT_GROUP_BY[$$90]  |PARTITIONED|
          exchange [cardinality: 1.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
          -- HASH_PARTITION_EXCHANGE [$$90]  |PARTITIONED|
            group by ([$$90 := $$80]) decor ([]) {
                      aggregate [$$89] <- [agg-local-sql-sum(sql-count($$84))] [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                      -- AGGREGATE  |LOCAL|
                        nested tuple source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                        -- NESTED_TUPLE_SOURCE  |LOCAL|
                   } [cardinality: 1.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
            -- SORT_GROUP_BY[$$80]  |PARTITIONED|
              exchange [cardinality: 1.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                select (eq(lowercase($$80), "string")) [cardinality: 1.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
                -- STREAM_SELECT  |PARTITIONED|
                  assign [$$80] <- [$$ht.getField("display_url")] project: [$$84, $$80] [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
                  -- ASSIGN  |PARTITIONED|
                    unnest $$ht <- scan-collection($$84) [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
                    -- UNNEST  |PARTITIONED|
                      assign [$$84] <- [$$p1.getField("entities").getField("urls")] project: [$$84] [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
                      -- ASSIGN  |PARTITIONED|
                        select (neq($$81, "0")) project: [$$p1] [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
                        -- STREAM_SELECT  |PARTITIONED|
                          exchange [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                            data-scan []<-[$$81, $$p1] <- test.ColumnDataset project ({entities:{urls:[{display_url:any}]}}) filter on: eq(lowercase(scan-collection($$p1.getField("entities").getField("urls")).getField("display_url")), "string") [cardinality: 2.0, doc-size: 0.0, op-cost: 0.0, total-cost: 2.0]
                            -- DATASOURCE_SCAN  |PARTITIONED|
                              exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                empty-tuple-source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                                -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
