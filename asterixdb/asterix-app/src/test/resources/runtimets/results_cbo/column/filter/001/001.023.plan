distribute result [$$item] [cardinality: 0.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange [cardinality: 0.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    project ([$$item]) [cardinality: 0.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
    -- STREAM_PROJECT  |PARTITIONED|
      exchange [cardinality: 0.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
      -- SORT_MERGE_EXCHANGE [$$31(ASC), $$item(ASC) ]  |PARTITIONED|
        order (ASC, $$31) (ASC, $$item) [cardinality: 0.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
        -- STABLE_SORT [$$31(ASC), $$item(ASC)]  |PARTITIONED|
          exchange [cardinality: 0.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
            select (gt($$item, 10000)) [cardinality: 0.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
            -- STREAM_SELECT  |PARTITIONED|
              unnest $$item <- scan-collection($$32) project: [$$31, $$item] [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
              -- UNNEST  |PARTITIONED|
                assign [$$32] <- [$$d.getField("array")] project: [$$31, $$32] [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
                -- ASSIGN  |PARTITIONED|
                  exchange [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                    data-scan []<-[$$31, $$d] <- test.ColumnDataset project ({array:[any]}) filter on: gt(scan-collection($$d.getField("array")), 10000) range-filter on: gt(scan-collection($$d.getField("array")), 10000) [cardinality: 6.0, doc-size: 106.0, op-cost: 0.0, total-cost: 6.0]
                    -- DATASOURCE_SCAN  |PARTITIONED|
                      exchange [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                        empty-tuple-source [cardinality: 0.0, doc-size: 0.0, op-cost: 0.0, total-cost: 0.0]
                        -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
