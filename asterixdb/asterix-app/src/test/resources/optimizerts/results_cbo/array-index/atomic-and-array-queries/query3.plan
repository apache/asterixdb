distribute result [$$57]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$57] <- [{"D": $$D, "DOI": $$DOI, "DII": $$DII}] project: [$$57]
    -- ASSIGN  |PARTITIONED|
      select (and(eq($$DII.getField("field3"), 3), eq($$DII.getField("field3_notindexed"), 3), eq($$DII.getField("field2"), 2)))
      -- STREAM_SELECT  |PARTITIONED|
        unnest $$DII <- scan-collection($$63) project: [$$D, $$DOI, $$DII]
        -- UNNEST  |PARTITIONED|
          select (eq($$DOI.getField("field2_notindexed"), 2))
          -- STREAM_SELECT  |PARTITIONED|
            assign [$$63] <- [$$DOI.getField("inner_items")]
            -- ASSIGN  |PARTITIONED|
              unnest $$DOI <- scan-collection($$61) project: [$$D, $$DOI]
              -- UNNEST  |PARTITIONED|
                select (and(eq($$D.getField("field4"), 4), eq($$D.getField("field1"), 1)))
                -- STREAM_SELECT  |PARTITIONED|
                  assign [$$61] <- [$$D.getField("outer_items")]
                  -- ASSIGN  |PARTITIONED|
                    project ([$$D])
                    -- STREAM_PROJECT  |PARTITIONED|
                      exchange
                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                        data-scan []<-[$$58, $$D] <- TestDataverse.Dataset1
                        -- DATASOURCE_SCAN  |PARTITIONED|
                          exchange
                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                            empty-tuple-source
                            -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
