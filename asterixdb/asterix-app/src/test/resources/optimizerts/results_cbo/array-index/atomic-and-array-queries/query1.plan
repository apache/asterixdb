distribute result [$$39]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$39] <- [{"D": $$D, "DI": $$DI}] project: [$$39]
    -- ASSIGN  |PARTITIONED|
      select (and(eq($$DI.getField("field2"), 2), eq($$DI.getField("field3"), 3)))
      -- STREAM_SELECT  |PARTITIONED|
        unnest $$DI <- scan-collection($$43) project: [$$D, $$DI]
        -- UNNEST  |PARTITIONED|
          select (and(eq($$D.getField("field4"), 4), eq($$D.getField("field1"), 1)))
          -- STREAM_SELECT  |PARTITIONED|
            assign [$$43] <- [$$D.getField("items")]
            -- ASSIGN  |PARTITIONED|
              project ([$$D])
              -- STREAM_PROJECT  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  data-scan []<-[$$40, $$D] <- TestDataverse.Dataset1
                  -- DATASOURCE_SCAN  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      empty-tuple-source
                      -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
