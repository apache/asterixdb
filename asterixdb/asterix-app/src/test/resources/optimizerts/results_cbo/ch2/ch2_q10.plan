distribute result [$$182]
-- DISTRIBUTE_RESULT  |UNPARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |UNPARTITIONED|
    limit 20
    -- STREAM_LIMIT  |UNPARTITIONED|
      assign [$$182] <- [{"c_id": $$c_id, "c_last": $$c_last, "revenue": $$198, "c_city": $$c_city, "c_phone": $$c_phone, "n_name": $$n_name}] project: [$$182]
      -- ASSIGN  |PARTITIONED|
        exchange
        -- SORT_MERGE_EXCHANGE [$$198(DESC) ]  |PARTITIONED|
          limit 20
          -- STREAM_LIMIT  |PARTITIONED|
            exchange
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              order (topK: 20) (DESC, $$198)
              -- STABLE_SORT [topK: 20] [$$198(DESC)]  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  group by ([$$c_id := $$207; $$c_last := $$208; $$c_city := $$209; $$c_phone := $$210; $$n_name := $$211]) decor ([]) {
                            aggregate [$$198] <- [agg-global-sql-sum($$206)]
                            -- AGGREGATE  |LOCAL|
                              nested tuple source
                              -- NESTED_TUPLE_SOURCE  |LOCAL|
                         }
                  -- SORT_GROUP_BY[$$207, $$208, $$209, $$210, $$211]  |PARTITIONED|
                    exchange
                    -- HASH_PARTITION_EXCHANGE [$$207, $$208, $$209, $$210, $$211]  |PARTITIONED|
                      group by ([$$207 := $$189; $$208 := $$184; $$209 := $$185; $$210 := $$186; $$211 := $$187]) decor ([]) {
                                aggregate [$$206] <- [agg-local-sql-sum($$179)]
                                -- AGGREGATE  |LOCAL|
                                  nested tuple source
                                  -- NESTED_TUPLE_SOURCE  |LOCAL|
                             }
                      -- SORT_GROUP_BY[$$189, $$184, $$185, $$186, $$187]  |PARTITIONED|
                        exchange
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          project ([$$179, $$189, $$184, $$185, $$186, $$187])
                          -- STREAM_PROJECT  |PARTITIONED|
                            exchange
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              join (eq($$199, $$200))
                              -- HYBRID_HASH_JOIN [$$200][$$199]  |PARTITIONED|
                                exchange
                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                  project ([$$179, $$189, $$184, $$185, $$186, $$200])
                                  -- STREAM_PROJECT  |PARTITIONED|
                                    exchange
                                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                      join (and(eq($$189, $$193), eq($$194, $$195), eq($$196, $$197)))
                                      -- HYBRID_HASH_JOIN [$$193, $$195, $$197][$$189, $$194, $$196]  |PARTITIONED|
                                        exchange
                                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                          assign [$$179] <- [$$ol.getField("ol_amount")] project: [$$179, $$193, $$195, $$197]
                                          -- ASSIGN  |PARTITIONED|
                                            unnest $$ol <- scan-collection($$202) project: [$$197, $$195, $$193, $$ol]
                                            -- UNNEST  |PARTITIONED|
                                              select (and(ge($$188, "2015-10-01 00:00:00.000000"), lt($$188, "2016-01-01 00:00:00.000000"))) project: [$$197, $$195, $$193, $$202]
                                              -- STREAM_SELECT  |PARTITIONED|
                                                assign [$$197, $$195, $$193, $$188, $$202] <- [$$o.getField("o_w_id"), $$o.getField("o_d_id"), $$o.getField("o_c_id"), $$o.getField("o_entry_d"), $$o.getField("o_orderline")] project: [$$197, $$195, $$193, $$188, $$202]
                                                -- ASSIGN  |PARTITIONED|
                                                  project ([$$o])
                                                  -- STREAM_PROJECT  |PARTITIONED|
                                                    exchange
                                                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                      data-scan []<-[$$192, $$o] <- test.orders
                                                      -- DATASOURCE_SCAN  |PARTITIONED|
                                                        exchange
                                                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                          empty-tuple-source
                                                          -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                                        exchange
                                        -- BROADCAST_EXCHANGE  |PARTITIONED|
                                          assign [$$200, $$186, $$185, $$184, $$196, $$194, $$189] <- [get-item(string-to-codepoint($$c.getField("c_state")), 0), $$c.getField("c_phone"), $$c.getField("c_city"), $$c.getField("c_last"), $$c.getField("c_w_id"), $$c.getField("c_d_id"), $$c.getField("c_id")] project: [$$189, $$184, $$185, $$186, $$200, $$194, $$196]
                                          -- ASSIGN  |PARTITIONED|
                                            project ([$$c])
                                            -- STREAM_PROJECT  |PARTITIONED|
                                              exchange
                                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                data-scan []<-[$$191, $$c] <- test.customer
                                                -- DATASOURCE_SCAN  |PARTITIONED|
                                                  exchange
                                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                    empty-tuple-source
                                                    -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                                exchange
                                -- BROADCAST_EXCHANGE  |PARTITIONED|
                                  assign [$$187, $$199] <- [$$n.getField("n_name"), $$n.getField("n_nationkey")] project: [$$187, $$199]
                                  -- ASSIGN  |PARTITIONED|
                                    project ([$$n])
                                    -- STREAM_PROJECT  |PARTITIONED|
                                      exchange
                                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                        data-scan []<-[$$190, $$n] <- test.nation
                                        -- DATASOURCE_SCAN  |PARTITIONED|
                                          exchange
                                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                            empty-tuple-source
                                            -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
