distribute result [$$x]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    select (or(eq($$21, "one"), $$27, $$27)) project: [$$x]
    -- STREAM_SELECT  |PARTITIONED|
      assign [$$27] <- [eq($$21, "two")]
      -- ASSIGN  |PARTITIONED|
        exchange
        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
          unnest-map [$$21, $$x] <- index-search("TestSet", 0, "Default", "test", "TestSet", false, true, 1, $$23, 1, $$23, true, true, true)
          -- BTREE_SEARCH  |PARTITIONED|
            exchange
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              order (ASC, $$23)
              -- STABLE_SORT [$$23(ASC)]  |PARTITIONED|
                exchange
                -- HASH_PARTITION_EXCHANGE [$$23]  |PARTITIONED|
                  unnest $$23 <- scan-collection(array: [ "one", "two" ])
                  -- UNNEST  |PARTITIONED|
                    empty-tuple-source
                    -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
