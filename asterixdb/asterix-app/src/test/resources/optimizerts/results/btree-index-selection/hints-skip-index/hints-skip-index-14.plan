                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                            unnest-map [$$26, $$27, $$28] <- index-search("idx_1k_2k", 0, "Default", "test", "tenk", false, false, 1, $$24, 1, $$24, true, true, true)
