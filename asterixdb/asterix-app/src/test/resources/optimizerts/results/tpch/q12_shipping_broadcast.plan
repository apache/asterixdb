distribute result [$$126]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$126] <- [{"l_shipmode": $$l_shipmode, "high_line_count": $$137, "low_line_count": $$138}] project: [$$126]
    -- ASSIGN  |PARTITIONED|
      exchange
      -- SORT_MERGE_EXCHANGE [$$l_shipmode(ASC) ]  |PARTITIONED|
        group by ([$$l_shipmode := $$145]) decor ([]) {
                  aggregate [$$137, $$138] <- [agg-global-sql-sum($$143), agg-global-sql-sum($$144)]
                  -- AGGREGATE  |LOCAL|
                    nested tuple source
                    -- NESTED_TUPLE_SOURCE  |LOCAL|
               }
        -- SORT_GROUP_BY[$$145]  |PARTITIONED|
          exchange
          -- HASH_PARTITION_EXCHANGE [$$145]  |PARTITIONED|
            group by ([$$145 := $$128]) decor ([]) {
                      aggregate [$$143, $$144] <- [agg-local-sql-sum(switch-case(true, or(eq($$133, "1-URGENT"), eq($$133, "2-HIGH")), numeric-add(1, numeric-multiply($$133, 0)), numeric-add(0, numeric-multiply($$133, 0)))), agg-local-sql-sum(switch-case(true, eq(true, or(eq($$133, "1-URGENT"), eq($$133, "2-HIGH"))), numeric-add(0, numeric-multiply($$133, 0)), numeric-add(1, numeric-multiply($$133, 0))))]
                      -- AGGREGATE  |LOCAL|
                        nested tuple source
                        -- NESTED_TUPLE_SOURCE  |LOCAL|
                   }
            -- SORT_GROUP_BY[$$128]  |PARTITIONED|
              exchange
              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                project ([$$133, $$128])
                -- STREAM_PROJECT  |PARTITIONED|
                  exchange
                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                    join (eq($$134, $$128))
                    -- HYBRID_HASH_JOIN [$$128][$$134]  |PARTITIONED|
                      exchange
                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                        project ([$$133, $$128])
                        -- STREAM_PROJECT  |PARTITIONED|
                          exchange
                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                            join (eq($$135, $$132))
                            -- HYBRID_HASH_JOIN [$$135][$$132]  |PARTITIONED|
                              exchange
                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                select (and(ge($$129, "1994-01-01"), lt($$129, "1995-01-01"), lt($$130, $$129), lt($$l.getField("l_shipdate"), $$130))) project: [$$128, $$135]
                                -- STREAM_SELECT  |PARTITIONED|
                                  assign [$$130, $$129, $$128, $$135] <- [$$l.getField("l_commitdate"), $$l.getField("l_receiptdate"), $$l.getField("l_shipmode"), $$l.getField("l_orderkey")]
                                  -- ASSIGN  |PARTITIONED|
                                    project ([$$l])
                                    -- STREAM_PROJECT  |PARTITIONED|
                                      exchange
                                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                        data-scan []<-[$$131, $$l] <- tpch.LineItem
                                        -- DATASOURCE_SCAN  |PARTITIONED|
                                          exchange
                                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                            empty-tuple-source
                                            -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                              exchange
                              -- BROADCAST_EXCHANGE  |PARTITIONED|
                                assign [$$133] <- [$$o.getField("o_orderpriority")] project: [$$133, $$132]
                                -- ASSIGN  |PARTITIONED|
                                  exchange
                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                    data-scan []<-[$$132, $$o] <- tpch.Orders
                                    -- DATASOURCE_SCAN  |PARTITIONED|
                                      exchange
                                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                        empty-tuple-source
                                        -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                      exchange
                      -- BROADCAST_EXCHANGE  |PARTITIONED|
                        unnest $$134 <- scan-collection(array: [ "MAIL", "SHIP" ])
                        -- UNNEST  |UNPARTITIONED|
                          empty-tuple-source
                          -- EMPTY_TUPLE_SOURCE  |UNPARTITIONED|
