distribute result [$$55]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$55] <- [object-concat-strict(to-object-var-str($$m), {"close": $$54})] project: [$$55]
    -- ASSIGN  |PARTITIONED|
      project ([$$54, $$m])
      -- STREAM_PROJECT  |PARTITIONED|
        exchange
        -- SORT_MERGE_EXCHANGE [$$79(ASC) ]  |PARTITIONED|
          group by ([$$79 := $$57]) decor ([$$m]) {
                    aggregate [$$54] <- [listify($$72)]
                    -- AGGREGATE  |LOCAL|
                      select (not(is-missing($$78)))
                      -- STREAM_SELECT  |LOCAL|
                        project ([$$72, $$78])
                        -- STREAM_PROJECT  |LOCAL|
                          nested tuple source
                          -- NESTED_TUPLE_SOURCE  |LOCAL|
                 }
          -- PRE_CLUSTERED_GROUP_BY[$$57]  |PARTITIONED|
            exchange
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              order (ASC, $$57) (ASC, $$74) (ASC, $$75)
              -- STABLE_SORT [$$57(ASC), $$74(ASC), $$75(ASC)]  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  project ([$$m, $$72, $$74, $$75, $$78, $$57])
                  -- STREAM_PROJECT  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      left outer join (eq($$57, $$67))
                      -- HYBRID_HASH_JOIN [$$57][$$67]  |PARTITIONED|
                        exchange
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          data-scan []<-[$$57, $$m] <- MovieTest.movies
                          -- DATASOURCE_SCAN  |PARTITIONED|
                            exchange
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              empty-tuple-source
                              -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                        exchange
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          assign [$$78, $$72, $$74, $$75] <- [true, $$69.getField(1), $$69.getField("41"), $$69.getField(3)] project: [$$72, $$74, $$75, $$78, $$67]
                          -- ASSIGN  |PARTITIONED|
                            unnest $$69 <- scan-collection($$68) project: [$$67, $$69]
                            -- UNNEST  |PARTITIONED|
                              exchange
                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                group by ([$$67 := $$65]) decor ([]) {
                                          aggregate [$$68] <- [listify($$66)]
                                          -- AGGREGATE  |LOCAL|
                                            limit 3
                                            -- STREAM_LIMIT  |LOCAL|
                                              project ([$$66])
                                              -- STREAM_PROJECT  |LOCAL|
                                                order (ASC, $$diff) (ASC, $$58)
                                                -- MICRO_STABLE_SORT [$$diff(ASC), $$58(ASC)]  |LOCAL|
                                                  project ([$$66, $$diff, $$58])
                                                  -- STREAM_PROJECT  |LOCAL|
                                                    nested tuple source
                                                    -- NESTED_TUPLE_SOURCE  |LOCAL|
                                       }
                                -- PRE_CLUSTERED_GROUP_BY[$$65]  |PARTITIONED|
                                  exchange
                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                    order (ASC, $$65)
                                    -- STABLE_SORT [$$65(ASC)]  |PARTITIONED|
                                      exchange
                                      -- HASH_PARTITION_MERGE_EXCHANGE MERGE:[$$65(ASC), $$diff(ASC), $$58(ASC)] HASH:[$$65]  |PARTITIONED|
                                        assign [$$66] <- [{"64": $$64, "52": to-object-var-str($$im), "40": $$im, "41": $$diff, "58": $$58, "60": $$60, "63": $$63}] project: [$$66, $$diff, $$58, $$65]
                                        -- ASSIGN  |PARTITIONED|
                                          exchange
                                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                            order (ASC, $$65) (ASC, $$diff) (ASC, $$58)
                                            -- STABLE_SORT [$$65(ASC), $$diff(ASC), $$58(ASC)]  |PARTITIONED|
                                              exchange
                                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                assign [$$diff] <- [abs(numeric-subtract($$63, $$60))]
                                                -- ASSIGN  |PARTITIONED|
                                                  exchange
                                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                    join (true)
                                                    -- NESTED_LOOP  |PARTITIONED|
                                                      exchange
                                                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                        assign [$$63] <- [$$64.getField("runtime")]
                                                        -- ASSIGN  |PARTITIONED|
                                                          exchange
                                                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                            data-scan []<-[$$65, $$64] <- MovieTest.movies
                                                            -- DATASOURCE_SCAN  |PARTITIONED|
                                                              exchange
                                                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                                empty-tuple-source
                                                                -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                                                      exchange
                                                      -- BROADCAST_EXCHANGE  |PARTITIONED|
                                                        assign [$$60] <- [$$im.getField("runtime")]
                                                        -- ASSIGN  |PARTITIONED|
                                                          exchange
                                                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                            data-scan []<-[$$58, $$im] <- MovieTest.movies
                                                            -- DATASOURCE_SCAN  |PARTITIONED|
                                                              exchange
                                                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                                empty-tuple-source
                                                                -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
