distribute result [$$50]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$50] <- [{"a_0": $$51, "a_1": $$52, "a_2": $$53, "a_3": $$63, "b_3": $$64}] project: [$$50]
    -- ASSIGN  |PARTITIONED|
      project ([$$51, $$52, $$53, $$63, $$64])
      -- STREAM_PROJECT  |PARTITIONED|
        exchange
        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
          left outer join (and(eq($$51, $$54), eq($$55, $$52), eq($$53, $$56), eq($$63, $$64)))
          -- HYBRID_HASH_JOIN [$$51, $$52, $$53, $$63][$$54, $$55, $$56, $$64]  |PARTITIONED|
            exchange
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              assign [$$63] <- [$$A.getField("a_3")] project: [$$51, $$52, $$53, $$63]
              -- ASSIGN  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  data-scan []<-[$$51, $$52, $$53, $$A] <- test.A
                  -- DATASOURCE_SCAN  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      empty-tuple-source
                      -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
            exchange
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              assign [$$64] <- [$$B.getField("b_3")] project: [$$64, $$54, $$55, $$56]
              -- ASSIGN  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  data-scan []<-[$$54, $$55, $$56, $$B] <- test.B
                  -- DATASOURCE_SCAN  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      empty-tuple-source
                      -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
