distribute result [$$47]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$47] <- [{"a_0": $$48, "a_1": $$49, "a_2": $$50, "a_3": $$58, "b_3": $$59}] project: [$$47]
    -- ASSIGN  |PARTITIONED|
      project ([$$48, $$49, $$50, $$58, $$59])
      -- STREAM_PROJECT  |PARTITIONED|
        exchange
        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
          left outer join (and(eq($$48, $$51), eq($$52, $$49), eq($$58, $$59)))
          -- HYBRID_HASH_JOIN [$$48, $$49, $$58][$$51, $$52, $$59]  |PARTITIONED|
            exchange
            -- HASH_PARTITION_EXCHANGE [$$48, $$49, $$58]  |PARTITIONED|
              assign [$$58] <- [$$A.getField("a_3")] project: [$$48, $$49, $$50, $$58]
              -- ASSIGN  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  data-scan []<-[$$48, $$49, $$50, $$A] <- test.A
                  -- DATASOURCE_SCAN  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      empty-tuple-source
                      -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
            exchange
            -- HASH_PARTITION_EXCHANGE [$$51, $$52, $$59]  |PARTITIONED|
              assign [$$59] <- [$$B.getField("b_3")] project: [$$59, $$51, $$52]
              -- ASSIGN  |PARTITIONED|
                project ([$$51, $$52, $$B])
                -- STREAM_PROJECT  |PARTITIONED|
                  exchange
                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                    data-scan []<-[$$51, $$52, $$53, $$B] <- test.B
                    -- DATASOURCE_SCAN  |PARTITIONED|
                      exchange
                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                        empty-tuple-source
                        -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
