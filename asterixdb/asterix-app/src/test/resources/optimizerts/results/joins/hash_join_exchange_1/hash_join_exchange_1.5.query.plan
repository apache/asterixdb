distribute result [$$47]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$47] <- [{"a_0": $$48, "a_1": $$49, "a_2": $$50, "a_3": $$63, "b_3": $$64}] project: [$$47]
    -- ASSIGN  |PARTITIONED|
      project ([$$48, $$49, $$50, $$63, $$64])
      -- STREAM_PROJECT  |PARTITIONED|
        exchange
        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
          left outer join (and(eq($$48, $$51), eq($$52, $$49), eq($$50, $$53)))
          -- HYBRID_HASH_JOIN [$$48, $$49, $$50][$$51, $$52, $$53]  |PARTITIONED|
            exchange
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              assign [$$63] <- [$$A.getField("a_3")] project: [$$48, $$49, $$50, $$63]
              -- ASSIGN  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  data-scan []<-[$$48, $$49, $$50, $$A] <- test.A
                  -- DATASOURCE_SCAN  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      empty-tuple-source
                      -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
            exchange
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              assign [$$64] <- [$$B.getField("b_3")] project: [$$64, $$51, $$52, $$53]
              -- ASSIGN  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  data-scan []<-[$$51, $$52, $$53, $$B] <- test.B
                  -- DATASOURCE_SCAN  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      empty-tuple-source
                      -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
