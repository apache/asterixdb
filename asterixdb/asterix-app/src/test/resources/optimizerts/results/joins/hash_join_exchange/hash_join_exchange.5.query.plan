distribute result [$$47]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$47] <- [object-concat-strict({"c_id": $$50}, to-object-var-str($$o))] project: [$$47]
    -- ASSIGN  |PARTITIONED|
      project ([$$50, $$o])
      -- STREAM_PROJECT  |PARTITIONED|
        exchange
        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
          left outer join (and(eq($$48, $$51), eq($$49, $$52), eq($$50, $$59)))
          -- HYBRID_HASH_JOIN [$$48, $$49, $$50][$$51, $$52, $$59]  |PARTITIONED|
            exchange
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              project ([$$50, $$48, $$49])
              -- STREAM_PROJECT  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  data-scan []<-[$$48, $$49, $$50, $$c] <- test.customer
                  -- DATASOURCE_SCAN  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      empty-tuple-source
                      -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
            exchange
            -- HASH_PARTITION_EXCHANGE [$$51, $$52, $$59]  |PARTITIONED|
              select (gt($$o.getField("o_carrier_id"), 8))
              -- STREAM_SELECT  |PARTITIONED|
                assign [$$59] <- [$$o.getField("o_c_id")]
                -- ASSIGN  |PARTITIONED|
                  project ([$$51, $$52, $$o])
                  -- STREAM_PROJECT  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      data-scan []<-[$$51, $$52, $$53, $$o] <- test.orders
                      -- DATASOURCE_SCAN  |PARTITIONED|
                        exchange
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          empty-tuple-source
                          -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
