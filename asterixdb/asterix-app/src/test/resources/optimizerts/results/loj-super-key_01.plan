distribute result [$$54]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$54] <- [{"li": $$li, "partsupp": $$52}] project: [$$54]
    -- ASSIGN  |PARTITIONED|
      project ([$$52, $$li])
      -- STREAM_PROJECT  |PARTITIONED|
        exchange
        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
          group by ([$$66 := $$55; $$67 := $$56]) decor ([$$li]) {
                    aggregate [$$52] <- [listify($$ps)]
                    -- AGGREGATE  |LOCAL|
                      select (not(is-missing($$65)))
                      -- STREAM_SELECT  |LOCAL|
                        project ([$$ps, $$65])
                        -- STREAM_PROJECT  |LOCAL|
                          nested tuple source
                          -- NESTED_TUPLE_SOURCE  |LOCAL|
                 }
          -- PRE_CLUSTERED_GROUP_BY[$$55, $$56]  |PARTITIONED|
            exchange
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              order (ASC, $$55) (ASC, $$56)
              -- STABLE_SORT [$$55(ASC), $$56(ASC)]  |PARTITIONED|
                exchange
                -- HASH_PARTITION_EXCHANGE [$$55, $$56]  |PARTITIONED|
                  project ([$$li, $$ps, $$65, $$55, $$56])
                  -- STREAM_PROJECT  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      left outer join (and(eq($$55, $$57), eq($$61, $$58), eq($$63, $$64)))
                      -- HYBRID_HASH_JOIN [$$55, $$61, $$63][$$57, $$58, $$64]  |PARTITIONED|
                        exchange
                        -- HASH_PARTITION_EXCHANGE [$$55, $$61]  |PARTITIONED|
                          assign [$$63, $$61] <- [$$li.getField(5), $$li.getField(2)]
                          -- ASSIGN  |PARTITIONED|
                            exchange
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              data-scan []<-[$$55, $$56, $$li] <- `loj-super-key_01`.LineItems
                              -- DATASOURCE_SCAN  |PARTITIONED|
                                exchange
                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                  empty-tuple-source
                                  -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                        exchange
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          assign [$$65, $$64] <- [true, $$ps.getField(3)]
                          -- ASSIGN  |PARTITIONED|
                            exchange
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              data-scan []<-[$$57, $$58, $$ps] <- `loj-super-key_01`.PartSupp
                              -- DATASOURCE_SCAN  |PARTITIONED|
                                exchange
                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                  empty-tuple-source
                                  -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
