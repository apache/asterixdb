distribute result [$$54]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$54] <- [{"partsupp": $$ps, "li": $$52}] project: [$$54]
    -- ASSIGN  |PARTITIONED|
      project ([$$52, $$ps])
      -- STREAM_PROJECT  |PARTITIONED|
        exchange
        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
          group by ([$$66 := $$55; $$67 := $$56]) decor ([$$ps]) {
                    aggregate [$$52] <- [listify($$li)]
                    -- AGGREGATE  |LOCAL|
                      select (not(is-missing($$65)))
                      -- STREAM_SELECT  |LOCAL|
                        project ([$$li, $$65])
                        -- STREAM_PROJECT  |LOCAL|
                          nested tuple source
                          -- NESTED_TUPLE_SOURCE  |LOCAL|
                 }
          -- PRE_CLUSTERED_GROUP_BY[$$55, $$56]  |PARTITIONED|
            exchange
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              order (ASC, $$55) (ASC, $$56)
              -- STABLE_SORT [$$55(ASC), $$56(ASC)]  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  project ([$$ps, $$li, $$65, $$55, $$56])
                  -- STREAM_PROJECT  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      left outer join (and(eq($$57, $$55), eq($$61, $$56), eq($$63, $$64)))
                      -- HYBRID_HASH_JOIN [$$55, $$56, $$64][$$57, $$61, $$63]  |PARTITIONED|
                        exchange
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          assign [$$64] <- [$$ps.getField(3)]
                          -- ASSIGN  |PARTITIONED|
                            exchange
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              data-scan []<-[$$55, $$56, $$ps] <- `loj-super-key_02`.PartSupp
                              -- DATASOURCE_SCAN  |PARTITIONED|
                                exchange
                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                  empty-tuple-source
                                  -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                        exchange
                        -- HASH_PARTITION_EXCHANGE [$$57, $$61]  |PARTITIONED|
                          assign [$$65, $$63, $$61] <- [true, $$li.getField(5), $$li.getField(2)]
                          -- ASSIGN  |PARTITIONED|
                            project ([$$57, $$li])
                            -- STREAM_PROJECT  |PARTITIONED|
                              exchange
                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                data-scan []<-[$$57, $$58, $$li] <- `loj-super-key_02`.LineItems
                                -- DATASOURCE_SCAN  |PARTITIONED|
                                  exchange
                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                    empty-tuple-source
                                    -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
