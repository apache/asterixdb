                                         }
                                  -- SORT_GROUP_BY[$$396, $$422, $$421, $$398, $$399, $$395, $$394, $$423]  |PARTITIONED|
                                    exchange
                                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                      project ([$$370, $$396, $$422, $$421, $$398, $$399, $$395, $$394, $$423])
                                      -- STREAM_PROJECT  |PARTITIONED|
                                        exchange
                                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                          left outer join (and(eq($$425, $$421), eq($$426, $$396), eq($$427, $$422), gt($$428, $$397)))
                                          -- HYBRID_HASH_JOIN [$$421, $$396, $$422][$$425, $$426, $$427]  |PARTITIONED|
                                            exchange
                                            -- HASH_PARTITION_EXCHANGE [$$421, $$396, $$422]  |PARTITIONED|
                                              project ([$$396, $$422, $$421, $$398, $$399, $$395, $$394, $$423, $$397])
                                              -- STREAM_PROJECT  |PARTITIONED|
                                                exchange
                                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                  join (and(eq($$396, $$395), eq($$408, $$394)))
                                                  -- HYBRID_HASH_JOIN [$$395, $$394][$$396, $$408]  |PARTITIONED|
                                                    exchange
                                                    -- HASH_PARTITION_EXCHANGE [$$395, $$394]  |PARTITIONED|
                                                      project ([$$398, $$399, $$395, $$394, $$423])
                                                      -- STREAM_PROJECT  |PARTITIONED|
                                                        exchange
                                                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                          join (eq($$418, $$399))
                                                          -- HYBRID_HASH_JOIN [$$399][$$418]  |PARTITIONED|
                                                            exchange
                                                            -- HASH_PARTITION_EXCHANGE [$$399]  |PARTITIONED|
                                                              project ([$$398, $$399, $$423])
                                                              -- STREAM_PROJECT  |PARTITIONED|
                                                                exchange
                                                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                                  join (eq($$417, $$398))
                                                                  -- HYBRID_HASH_JOIN [$$398][$$417]  |PARTITIONED|
                                                                    exchange
                                                                    -- HASH_PARTITION_EXCHANGE [$$398]  |PARTITIONED|
                                                                      select (eq($$n.getField("n_name"), "Peru")) project: [$$398]
                                                                      -- STREAM_SELECT  |PARTITIONED|
                                                                        assign [$$398] <- [$$n.getField("n_nationkey")]
                                                                        -- ASSIGN  |PARTITIONED|
                                                                          project ([$$n])
                                                                          -- STREAM_PROJECT  |PARTITIONED|
                                                                            exchange
                                                                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                                              data-scan []<-[$$401, $$n] <- test.nation
                                                                              -- DATASOURCE_SCAN  |PARTITIONED|
                                                                                exchange
                                                                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                                                  empty-tuple-source
                                                                                  -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                                                                    exchange
                                                                    -- HASH_PARTITION_EXCHANGE [$$417]  |PARTITIONED|
                                                                      assign [$$423, $$399, $$417] <- [$$su.getField("su_name"), $$su.getField("su_suppkey"), $$su.getField("su_nationkey")] project: [$$399, $$423, $$417]
                                                                      -- ASSIGN  |PARTITIONED|
                                                                        project ([$$su])
                                                                        -- STREAM_PROJECT  |PARTITIONED|
                                                                          exchange
                                                                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                                            data-scan []<-[$$402, $$su] <- test.supplier
