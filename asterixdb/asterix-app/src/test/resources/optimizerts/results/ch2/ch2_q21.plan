distribute result [$$383]
-- DISTRIBUTE_RESULT  |UNPARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |UNPARTITIONED|
    limit 100
    -- STREAM_LIMIT  |UNPARTITIONED|
      project ([$$383])
      -- STREAM_PROJECT  |PARTITIONED|
        exchange
        -- SORT_MERGE_EXCHANGE [$$su_name(ASC) ]  |PARTITIONED|
          assign [$$383] <- [{"su_name": $$su_name, "numwait": $$407}] project: [$$su_name, $$383]
          -- ASSIGN  |PARTITIONED|
            limit 100
            -- STREAM_LIMIT  |PARTITIONED|
              exchange
              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                group by ([$$su_name := $$443]) decor ([]) {
                          aggregate [$$407] <- [agg-sql-sum($$442)]
                          -- AGGREGATE  |LOCAL|
                            nested tuple source
                            -- NESTED_TUPLE_SOURCE  |LOCAL|
                       }
                -- SORT_GROUP_BY[$$443]  |PARTITIONED|
                  exchange
                  -- HASH_PARTITION_EXCHANGE [$$443]  |PARTITIONED|
                    group by ([$$443 := $$su_name]) decor ([]) {
                              aggregate [$$442] <- [agg-sql-count(1)]
                              -- AGGREGATE  |LOCAL|
                                nested tuple source
                                -- NESTED_TUPLE_SOURCE  |LOCAL|
                           }
                    -- SORT_GROUP_BY[$$su_name]  |PARTITIONED|
                      exchange
                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                        select (eq($$406, 0)) project: [$$su_name]
                        -- STREAM_SELECT  |PARTITIONED|
                          project ([$$406, $$su_name])
                          -- STREAM_PROJECT  |PARTITIONED|
                            exchange
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              group by ([$$o_w_id := $$434; $$o_d_id := $$435; $$o_id := $$436; $$n_nationkey := $$437; $$su_suppkey := $$438; $$s_w_id := $$439; $$s_i_id := $$440; $$su_name := $$441]) decor ([]) {
                                        aggregate [$$406] <- [agg-sql-sum($$433)]
