                                          nested tuple source
                                          -- NESTED_TUPLE_SOURCE  |LOCAL|
                                     }
                              -- SORT_GROUP_BY[$$434, $$435, $$436, $$437, $$438, $$439, $$440, $$441]  |PARTITIONED|
                                exchange
                                -- HASH_PARTITION_EXCHANGE [$$434, $$435, $$436, $$437, $$438, $$439, $$440, $$441]  |PARTITIONED|
                                  group by ([$$434 := $$396; $$435 := $$422; $$436 := $$421; $$437 := $$398; $$438 := $$399; $$439 := $$395; $$440 := $$394; $$441 := $$423]) decor ([]) {
                                            aggregate [$$433] <- [agg-sql-count($$370)]
