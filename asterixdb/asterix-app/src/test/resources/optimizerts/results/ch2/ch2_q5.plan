                                                    unnest $$ol <- scan-collection($$300) project: [$$292, $$290, $$283, $$ol]
                                                    -- UNNEST  |PARTITIONED|
                                                      select (and(ge($$282, "2016-01-01 00:00:00.000000"), lt($$282, "2017-01-01 00:00:00.000000"))) project: [$$292, $$290, $$283, $$300]
