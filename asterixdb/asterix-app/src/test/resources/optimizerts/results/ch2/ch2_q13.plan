distribute result [$$145]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$145] <- [{"c_count": $$c_count, "custdist": $$151}] project: [$$145]
    -- ASSIGN  |PARTITIONED|
      exchange
      -- SORT_MERGE_EXCHANGE [$$151(DESC), $$c_count(DESC) ]  |PARTITIONED|
        order (DESC, $$151) (DESC, $$c_count)
        -- STABLE_SORT [$$151(DESC), $$c_count(DESC)]  |PARTITIONED|
          exchange
          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
            group by ([$$c_count := $$165]) decor ([]) {
                      aggregate [$$151] <- [agg-sql-sum($$164)]
                      -- AGGREGATE  |LOCAL|
                        nested tuple source
                        -- NESTED_TUPLE_SOURCE  |LOCAL|
                   }
            -- SORT_GROUP_BY[$$165]  |PARTITIONED|
              exchange
              -- HASH_PARTITION_EXCHANGE [$$165]  |PARTITIONED|
                group by ([$$165 := $$150]) decor ([]) {
                          aggregate [$$164] <- [agg-sql-count(1)]
                          -- AGGREGATE  |LOCAL|
                            nested tuple source
                            -- NESTED_TUPLE_SOURCE  |LOCAL|
                       }
                -- SORT_GROUP_BY[$$150]  |PARTITIONED|
                  exchange
                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                    project ([$$150])
                    -- STREAM_PROJECT  |PARTITIONED|
                      exchange
                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                        group by ([$$c_id := $$163]) decor ([]) {
                                  aggregate [$$150] <- [agg-sql-sum($$162)]
                                  -- AGGREGATE  |LOCAL|
                                    nested tuple source
                                    -- NESTED_TUPLE_SOURCE  |LOCAL|
                               }
                        -- SORT_GROUP_BY[$$163]  |PARTITIONED|
                          exchange
                          -- HASH_PARTITION_EXCHANGE [$$163]  |PARTITIONED|
                            group by ([$$163 := $$156]) decor ([]) {
                                      aggregate [$$162] <- [agg-sql-count($$134)]
                                      -- AGGREGATE  |LOCAL|
                                        nested tuple source
                                        -- NESTED_TUPLE_SOURCE  |LOCAL|
                                   }
                            -- SORT_GROUP_BY[$$156]  |PARTITIONED|
                              exchange
                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                project ([$$134, $$156])
                                -- STREAM_PROJECT  |PARTITIONED|
                                  exchange
                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                    left outer join (and(eq($$152, $$153), eq($$154, $$155), eq($$156, $$157)))
                                    -- HYBRID_HASH_JOIN [$$152, $$154, $$156][$$153, $$155, $$157]  |PARTITIONED|
                                      exchange
                                      -- HASH_PARTITION_EXCHANGE [$$152, $$154, $$156]  |PARTITIONED|
                                        assign [$$156, $$154, $$152] <- [$$c.getField("c_id"), $$c.getField("c_d_id"), $$c.getField("c_w_id")] project: [$$156, $$152, $$154]
                                        -- ASSIGN  |PARTITIONED|
                                          project ([$$c])
                                          -- STREAM_PROJECT  |PARTITIONED|
                                            exchange
                                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                              data-scan []<-[$$148, $$c] <- test.customer
                                              -- DATASOURCE_SCAN  |PARTITIONED|
                                                exchange
                                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                  empty-tuple-source
                                                  -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                                      exchange
                                      -- HASH_PARTITION_EXCHANGE [$$153, $$155, $$157]  |PARTITIONED|
                                        select (gt($$o.getField("o_carrier_id"), 8)) project: [$$134, $$153, $$155, $$157]
                                        -- STREAM_SELECT  |PARTITIONED|
                                          assign [$$157, $$155, $$153, $$134] <- [$$o.getField("o_c_id"), $$o.getField("o_d_id"), $$o.getField("o_w_id"), $$o.getField("o_id")]
                                          -- ASSIGN  |PARTITIONED|
                                            project ([$$o])
                                            -- STREAM_PROJECT  |PARTITIONED|
                                              exchange
                                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                data-scan []<-[$$149, $$o] <- test.orders
                                                -- DATASOURCE_SCAN  |PARTITIONED|
                                                  exchange
                                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                    empty-tuple-source
                                                    -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
