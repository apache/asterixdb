distribute result [$$148]
-- DISTRIBUTE_RESULT  |UNPARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |UNPARTITIONED|
    aggregate [$$148] <- [agg-sql-sum($$156)]
    -- AGGREGATE  |UNPARTITIONED|
      exchange
      -- RANDOM_MERGE_EXCHANGE  |PARTITIONED|
        aggregate [$$156] <- [agg-sql-count(1)]
        -- AGGREGATE  |PARTITIONED|
          exchange
          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
            join (eq($$138, $$139))
            -- HYBRID_HASH_JOIN [$$139][$$138]  |PARTITIONED|
              exchange
              -- HASH_PARTITION_EXCHANGE [$$139]  |PARTITIONED|
                project ([$$139])
                -- STREAM_PROJECT  |PARTITIONED|
                  exchange
                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                    join (eq($$153, $$154))
                    -- HYBRID_HASH_JOIN [$$154][$$153]  |PARTITIONED|
                      exchange
                      -- HASH_PARTITION_EXCHANGE [$$154]  |PARTITIONED|
                        select (eq($$r.getField("r_name"), "EUROPE")) project: [$$154]
                        -- STREAM_SELECT  |PARTITIONED|
                          assign [$$154] <- [$$r.getField("r_regionkey")]
                          -- ASSIGN  |PARTITIONED|
                            project ([$$r])
                            -- STREAM_PROJECT  |PARTITIONED|
                              exchange
                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                data-scan []<-[$$140, $$r] <- test.region
                                -- DATASOURCE_SCAN  |PARTITIONED|
                                  exchange
                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                    empty-tuple-source
                                    -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                      exchange
                      -- HASH_PARTITION_EXCHANGE [$$153]  |PARTITIONED|
                        assign [$$139, $$153] <- [$$n.getField("n_nationkey"), $$n.getField("n_regionkey")] project: [$$139, $$153]
                        -- ASSIGN  |PARTITIONED|
                          project ([$$n])
                          -- STREAM_PROJECT  |PARTITIONED|
                            exchange
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              data-scan []<-[$$141, $$n] <- test.nation
                              -- DATASOURCE_SCAN  |PARTITIONED|
                                exchange
                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                  empty-tuple-source
                                  -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
              exchange
              -- HASH_PARTITION_EXCHANGE [$$138]  |PARTITIONED|
                project ([$$138])
                -- STREAM_PROJECT  |PARTITIONED|
                  exchange
                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                    join (and(eq($$137, $$138), eq($$146, $$147)))
                    -- HYBRID_HASH_JOIN [$$137, $$146][$$138, $$147]  |PARTITIONED|
                      exchange
                      -- HASH_PARTITION_EXCHANGE [$$137, $$146]  |PARTITIONED|
                        project ([$$137, $$146])
                        -- STREAM_PROJECT  |PARTITIONED|
                          exchange
                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                            join (eq($$151, $$152))
                            -- HYBRID_HASH_JOIN [$$152][$$151]  |PARTITIONED|
                              exchange
                              -- HASH_PARTITION_EXCHANGE [$$152]  |PARTITIONED|
                                project ([$$137, $$152])
                                -- STREAM_PROJECT  |PARTITIONED|
                                  exchange
                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                    join (eq($$149, $$150))
                                    -- HYBRID_HASH_JOIN [$$149][$$150]  |PARTITIONED|
                                      exchange
                                      -- HASH_PARTITION_EXCHANGE [$$149]  |PARTITIONED|
                                        assign [$$137, $$149] <- [$$c.getField("c_nationkey"), $$c.getField("c_custkey")] project: [$$137, $$149]
                                        -- ASSIGN  |PARTITIONED|
                                          project ([$$c])
                                          -- STREAM_PROJECT  |PARTITIONED|
                                            exchange
                                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                              data-scan []<-[$$142, $$c] <- test.customer
                                              -- DATASOURCE_SCAN  |PARTITIONED|
                                                exchange
                                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                  empty-tuple-source
                                                  -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                                      exchange
                                      -- HASH_PARTITION_EXCHANGE [$$150]  |PARTITIONED|
                                        select (and(lt($$136, "1993-04-01"), ge($$136, "1993-01-01"))) project: [$$152, $$150]
                                        -- STREAM_SELECT  |PARTITIONED|
                                          assign [$$152, $$136, $$150] <- [$$o.getField("o_orderkey"), $$o.getField("o_orderdate"), $$o.getField("o_custkey")] project: [$$152, $$136, $$150]
                                          -- ASSIGN  |PARTITIONED|
                                            project ([$$o])
                                            -- STREAM_PROJECT  |PARTITIONED|
                                              exchange
                                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                data-scan []<-[$$143, $$o] <- test.orders
                                                -- DATASOURCE_SCAN  |PARTITIONED|
                                                  exchange
                                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                    empty-tuple-source
                                                    -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                              exchange
                              -- HASH_PARTITION_EXCHANGE [$$151]  |PARTITIONED|
                                assign [$$146, $$151] <- [$$l.getField("l_suppkey"), $$l.getField("l_orderkey")] project: [$$146, $$151]
                                -- ASSIGN  |PARTITIONED|
                                  project ([$$l])
                                  -- STREAM_PROJECT  |PARTITIONED|
                                    exchange
                                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                      data-scan []<-[$$144, $$l] <- test.lineitem
                                      -- DATASOURCE_SCAN  |PARTITIONED|
                                        exchange
                                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                          empty-tuple-source
                                          -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
                      exchange
                      -- HASH_PARTITION_EXCHANGE [$$138, $$147]  |PARTITIONED|
                        assign [$$138, $$147] <- [$$s.getField("s_nationkey"), $$s.getField("s_suppkey")] project: [$$138, $$147]
                        -- ASSIGN  |PARTITIONED|
                          project ([$$s])
                          -- STREAM_PROJECT  |PARTITIONED|
                            exchange
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              data-scan []<-[$$145, $$s] <- test.supplier
                              -- DATASOURCE_SCAN  |PARTITIONED|
                                exchange
                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                  empty-tuple-source
                                  -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
