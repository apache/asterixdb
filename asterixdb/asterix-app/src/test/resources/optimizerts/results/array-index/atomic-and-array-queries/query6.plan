distribute result [$$81]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$81] <- [{"D2": $$D2, "D1IV": {"field1": $$97, "field2": $$98, "field3": $$99, "field4": $$100}}] project: [$$81]
    -- ASSIGN  |PARTITIONED|
      select (and(eq($$100, $$85), eq($$99, $$87), eq($$98, $$89), eq($$97, $$91))) project: [$$D2, $$100, $$97, $$99, $$98]
      -- STREAM_SELECT  |PARTITIONED|
        assign [$$99, $$98] <- [$$D1I.getField("field3"), $$D1I.getField("field2")] project: [$$D2, $$91, $$89, $$87, $$85, $$100, $$97, $$99, $$98]
        -- ASSIGN  |PARTITIONED|
          unnest $$D1I <- scan-collection($$96) project: [$$D2, $$91, $$89, $$87, $$85, $$100, $$97, $$D1I]
          -- UNNEST  |PARTITIONED|
            assign [$$100, $$97, $$96] <- [$$D1.getField("field4"), $$D1.getField("field1"), $$D1.getField("items")] project: [$$D2, $$91, $$89, $$87, $$85, $$100, $$97, $$96]
            -- ASSIGN  |PARTITIONED|
              project ([$$D2, $$91, $$89, $$87, $$85, $$D1])
              -- STREAM_PROJECT  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  unnest-map [$$83, $$D1] <- index-search("Dataset1", 0, "Default", "TestDataverse", "Dataset1", true, false, 1, $$105, 1, $$105, true, true, true)
                  -- BTREE_SEARCH  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      project ([$$105, $$D2, $$91, $$89, $$87, $$85])
                      -- STREAM_PROJECT  |PARTITIONED|
                        exchange
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          distinct ([$$105, $$106])
                          -- PRE_SORTED_DISTINCT_BY  |PARTITIONED|
                            exchange
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              order (ASC, $$105) (ASC, $$106)
                              -- STABLE_SORT [$$105(ASC), $$106(ASC)]  |PARTITIONED|
                                exchange
                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                  project ([$$D2, $$91, $$89, $$87, $$85, $$106, $$105])
                                  -- STREAM_PROJECT  |PARTITIONED|
                                    exchange
                                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                      unnest-map [$$101, $$102, $$103, $$104, $$105] <- index-search("d1Idx", 0, "Default", "TestDataverse", "Dataset1", true, true, 4, $$91, $$89, $$87, $$85, 4, $$91, $$89, $$87, $$85, true, true, true)
                                      -- BTREE_SEARCH  |PARTITIONED|
                                        exchange
                                        -- BROADCAST_EXCHANGE  |PARTITIONED|
                                          running-aggregate [$$106] <- [create-query-uid()]
                                          -- RUNNING_AGGREGATE  |PARTITIONED|
                                            assign [$$91, $$89, $$87, $$85] <- [to-bigint($$D2.getField("field1")), to-bigint($$D2.getField("field2")), to-bigint($$D2.getField("field3")), to-bigint($$D2.getField("field4"))]
                                            -- ASSIGN  |PARTITIONED|
                                              project ([$$D2])
                                              -- STREAM_PROJECT  |PARTITIONED|
                                                exchange
                                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                  data-scan []<-[$$82, $$D2] <- TestDataverse.Dataset2
                                                  -- DATASOURCE_SCAN  |PARTITIONED|
                                                    exchange
                                                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                                      empty-tuple-source
                                                      -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
