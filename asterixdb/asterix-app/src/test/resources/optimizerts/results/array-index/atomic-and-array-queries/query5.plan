                                    unnest-map [$$81, $$82, $$83, $$84, $$85] <- index-search("d1Idx", 0, "Default", "TestDataverse", "Dataset1", false, false, 4, $$73, $$74, $$75, $$76, 4, $$77, $$78, $$79, $$80, true, true, true)
