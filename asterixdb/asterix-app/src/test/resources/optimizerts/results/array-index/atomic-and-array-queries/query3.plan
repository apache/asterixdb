distribute result [$$57]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$57] <- [{"D": $$D, "DOI": $$DOI, "DII": $$DII}] project: [$$57]
    -- ASSIGN  |PARTITIONED|
      select (and(eq($$DII.getField("field3"), 3), eq($$DII.getField("field3_notindexed"), 3), eq($$DII.getField("field2"), 2)))
      -- STREAM_SELECT  |PARTITIONED|
        unnest $$DII <- scan-collection($$63) project: [$$D, $$DOI, $$DII]
        -- UNNEST  |PARTITIONED|
          select (eq($$DOI.getField("field2_notindexed"), 2))
          -- STREAM_SELECT  |PARTITIONED|
            assign [$$63] <- [$$DOI.getField("inner_items")]
            -- ASSIGN  |PARTITIONED|
              unnest $$DOI <- scan-collection($$61) project: [$$D, $$DOI]
              -- UNNEST  |PARTITIONED|
                select (and(eq($$D.getField("field4"), 4), eq($$D.getField("field1"), 1)))
                -- STREAM_SELECT  |PARTITIONED|
                  assign [$$61] <- [$$D.getField("outer_items")]
                  -- ASSIGN  |PARTITIONED|
                    project ([$$D])
                    -- STREAM_PROJECT  |PARTITIONED|
                      exchange
                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                        unnest-map [$$58, $$D] <- index-search("Dataset1", 0, "Default", "TestDataverse", "Dataset1", false, false, 1, $$79, 1, $$79, true, true, true)
                        -- BTREE_SEARCH  |PARTITIONED|
                          exchange
                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                            distinct ([$$79])
                            -- PRE_SORTED_DISTINCT_BY  |PARTITIONED|
                              exchange
                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                order (ASC, $$79)
                                -- STABLE_SORT [$$79(ASC)]  |PARTITIONED|
                                  exchange
                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                    project ([$$79])
                                    -- STREAM_PROJECT  |PARTITIONED|
                                      exchange
                                      -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                        unnest-map [$$75, $$76, $$77, $$78, $$79] <- index-search("d1Idx", 0, "Default", "TestDataverse", "Dataset1", false, false, 4, $$67, $$68, $$69, $$70, 4, $$71, $$72, $$73, $$74, true, true, true)
                                        -- BTREE_SEARCH  |PARTITIONED|
                                          exchange
                                          -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                            assign [$$67, $$68, $$69, $$70, $$71, $$72, $$73, $$74] <- [1, 2, 3, 4, 1, 2, 3, 4]
                                            -- ASSIGN  |PARTITIONED|
                                              empty-tuple-source
                                              -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
