distribute result [$$43]
-- DISTRIBUTE_RESULT  |PARTITIONED|
  exchange
  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
    assign [$$43] <- [{"D": $$D, "DI": $$DI}] project: [$$43]
    -- ASSIGN  |PARTITIONED|
      select (and(eq($$DI.getField("field3"), 3), eq($$DI.getField("field3_notindexed"), 3), eq($$DI.getField("field2"), 2)))
      -- STREAM_SELECT  |PARTITIONED|
        unnest $$DI <- scan-collection($$48) project: [$$D, $$DI]
        -- UNNEST  |PARTITIONED|
          select (and(eq($$D.getField("field4"), 4), eq($$D.getField("field1"), 1), eq($$D.getField("field4_notindexed"), 4)))
          -- STREAM_SELECT  |PARTITIONED|
            assign [$$48] <- [$$D.getField("items")]
            -- ASSIGN  |PARTITIONED|
              project ([$$D])
              -- STREAM_PROJECT  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  unnest-map [$$44, $$D] <- index-search("Dataset1", 0, "Default", "TestDataverse", "Dataset1", false, false, 1, $$64, 1, $$64, true, true, true)
                  -- BTREE_SEARCH  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      distinct ([$$64])
                      -- PRE_SORTED_DISTINCT_BY  |PARTITIONED|
                        exchange
                        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                          order (ASC, $$64)
                          -- STABLE_SORT [$$64(ASC)]  |PARTITIONED|
                            exchange
                            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                              project ([$$64])
                              -- STREAM_PROJECT  |PARTITIONED|
                                exchange
                                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                  unnest-map [$$60, $$61, $$62, $$63, $$64] <- index-search("d1Idx", 0, "Default", "TestDataverse", "Dataset1", false, false, 4, $$52, $$53, $$54, $$55, 4, $$56, $$57, $$58, $$59, true, true, true)
                                  -- BTREE_SEARCH  |PARTITIONED|
                                    exchange
                                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                      assign [$$52, $$53, $$54, $$55, $$56, $$57, $$58, $$59] <- [1, 2, 3, 4, 1, 2, 3, 4]
                                      -- ASSIGN  |PARTITIONED|
                                        empty-tuple-source
                                        -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
