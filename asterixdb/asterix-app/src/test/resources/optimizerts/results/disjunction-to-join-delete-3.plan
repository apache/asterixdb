commit
-- COMMIT  |PARTITIONED|
  project ([$$19])
  -- STREAM_PROJECT  |PARTITIONED|
    exchange
    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
      delete from TestSetIndex on test.TestSet from [$$23]
      -- INDEX_INSERT_DELETE  |PARTITIONED|
        exchange
        -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
          project ([$$23, $$19])
          -- STREAM_PROJECT  |PARTITIONED|
            exchange
            -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
              delete from test.TestSet from record: $$TestSet partitioned by [$$19]
              -- INSERT_DELETE  |PARTITIONED|
                exchange
                -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                  materialize
                  -- MATERIALIZE  |PARTITIONED|
                    exchange
                    -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                      assign [$$23, $$19] <- [$$TestSet.getField(1), $$TestSet.getField(0)]
                      -- ASSIGN  |PARTITIONED|
                        select (or(eq($$21, "one"), eq($$21, "two"))) project: [$$TestSet]
                        -- STREAM_SELECT  |PARTITIONED|
                          assign [$$21] <- [$$TestSet.getField(2)]
                          -- ASSIGN  |PARTITIONED|
                            project ([$$TestSet])
                            -- STREAM_PROJECT  |PARTITIONED|
                              exchange
                              -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                data-scan []<-[$$20, $$TestSet] <- test.TestSet
                                -- DATASOURCE_SCAN  |PARTITIONED|
                                  exchange
                                  -- ONE_TO_ONE_EXCHANGE  |PARTITIONED|
                                    empty-tuple-source
                                    -- EMPTY_TUPLE_SOURCE  |PARTITIONED|
